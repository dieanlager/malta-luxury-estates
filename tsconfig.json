{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    },
    "experimentalDecorators": true,
    "typeRoots": ["./typings", "./node_modules/@types"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/backups", "src-backup-*", "backup-*", "backups", "masterplan-backup-complete", "masterplan-backup-*", "server-prod-backup*", "server-prod.ts", "src/main.tsx", "src/App.tsx", "src/vite-env.d.ts", "src/vite-pages/**"]
}
